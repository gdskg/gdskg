{
    "_comment": "Copy one of these entries into your IDE's mcp_config.json under 'mcpServers'. Replace placeholder paths and tokens with your own values.",
    "mcpServers": {
        "gdskg": {
            "_comment": "Docker-based server (recommended).",
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "-e",
                "GITHUB_TOKEN=<GITHUB_TOKEN>",
                "<YOUR_CUSTOM_IMAGE_URL>",
                "serve",
                "--transport",
                "stdio"
            ]
        },
        "gdskg_local": {
            "_comment": "Local python execution (requires requirements.txt installed). No Docker required.",
            "command": "python",
            "args": [
                "-m",
                "main",
                "serve",
                "--transport",
                "stdio"
            ],
            "env": {
                "GITHUB_TOKEN": "<GITHUB_TOKEN>"
            }
        }
    }
}